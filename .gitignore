# Local-only snapshots / backups (not tracked — git history is the real record)
Archive/

# Claude Code local settings & transcripts
.claude/

# R / RStudio working files
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.rds
*.qs

# Rendered Rmd output is regenerated from source; keep the .Rmd, ignore the build
rmd/**/*.html
rmd/**/*_cache/
rmd/**/*_files/

# OS cruft
Thumbs.db
Desktop.ini
.DS_Store

# Un-optimized source gif (the optimized HD-ezgif*.gif is the one the page uses)
HD.gif

# Landing-page source art (large PNGs/MP4; compressed WebP/webm copies live in assets/)
landing/

# Throwaway build / preview scratch files (Python edit scripts, headless screenshots, dumps)
_*.py
_*.html
_*.txt
_*.png
_*.webp
_*.svg
